# ============================================
# SweetCraft SaaS - Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# Flask
FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=production

# Admin Passwords (CHANGE THESE!)
ADMIN_PASSWORD=your_secure_admin_password
SUPERADMIN_PASSWORD=your_secure_superadmin_password

# CORS - set to your frontend domain in production
FRONTEND_URL=https://yourdomain.com

# ---- DATABASE ----
# Option 1: PostgreSQL (recommended for production)
DB_URI=postgresql://sweetcraft_user:your_db_password@postgres:5432/sweetcraft

# Option 2: SQLite (development only)
# DB_URI=sqlite:///shop.db

# ---- PostgreSQL (if using docker-compose) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sweetcraft
POSTGRES_USER=sweetcraft_user
POSTGRES_PASSWORD=your_db_password
